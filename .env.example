# Cognova Environment Variables
# Copy this file to .env and fill in your values

# =============================================================================
# REQUIRED
# =============================================================================

# PostgreSQL connection string
# Local dev (docker compose up -d):
NUXT_DATABASE_URL=postgres://postgres:postgres@localhost:5432/cognova

# Auth secret - generate with: openssl rand -base64 32
NUXT_BETTER_AUTH_SECRET=your-secret-here-generate-with-openssl

# Base URL of your application
NUXT_BETTER_AUTH_URL=http://localhost:3000

# Path to knowledge directory
NUXT_KNOWLEDGE_PATH=~/knowledge

# Encryption key for secrets/provider keys - generate with: openssl rand -hex 32
NUXT_ENCRYPTION_KEY=your-32-byte-hex-key-here

# =============================================================================
# OPTIONAL - Initial Admin User
# =============================================================================

# On first startup, a default admin user is created.
# NUXT_ADMIN_EMAIL=admin@example.com
# NUXT_ADMIN_PASSWORD=changeme123
# NUXT_ADMIN_NAME=Admin

# =============================================================================
# OPTIONAL - AI Provider API Keys
# =============================================================================

# Provider keys can also be configured via Settings > Providers in the UI.
# These env vars serve as fallbacks.

# NUXT_ANTHROPIC_API_KEY=sk-ant-...
# NUXT_OPENAI_API_KEY=sk-...
